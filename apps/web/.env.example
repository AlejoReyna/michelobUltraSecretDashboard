# Option A (recommended): use the same remote EC2 exporter as Vercel
AGENT_EXPORTER_URL=https://your-ec2-exporter.example.com
# If the token contains $, escape it for Next.js: "secret\$token"
AGENT_EXPORTER_TOKEN=your-exporter-token

# Option B: local exporter (run agent-exporter on port 8787 first)
# AGENT_EXPORTER_URL=http://localhost:8787
# AGENT_EXPORTER_TOKEN=dev-token

# Option C: offline demo data only
# USE_MOCK_AGENT_DATA=true
USE_MOCK_AGENT_DATA=false

# Market Intel GPT (server-side only — never expose to the browser)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_FALLBACK_MODEL=gpt-4.1-nano
OPENAI_TIMEOUT_MS=15000
