CASCADE_AI_PATH=/home/ec2-user/cascade-ai
AGENT_EXPORTER_TOKEN=change-me
VERCEL_DASHBOARD_ORIGIN=https://bot.alexisreyna.dev
PORT=8787
HOME=/home/ec2-user
PATH=/home/ec2-user/.npm-global/bin:/usr/local/bin:/usr/bin:/bin
TWAK_BIN=/home/ec2-user/.npm-global/bin/twak
TWAK_REFRESH_INTERVAL_MS=300000
TWAK_ERROR_RETRY_MS=60000
TWAK_COMMAND_TIMEOUT_MS=8000

# Optional S3 logs integration. The exporter will list and presign objects from
# this bucket/prefix when the EC2 instance (or credentials) has S3 access.
# S3_LOGS_BUCKET=your-logs-bucket
# S3_LOGS_PREFIX=logs/
# S3_LOGS_REGION=us-east-1
